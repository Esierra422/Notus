PORT=3001
# For production (e.g. Render), comma-separated exact origins (include www if you use it): https://notusapp.com,https://www.notusapp.com
CLIENT_URL=http://localhost:5173

# Firebase Admin SDK (for server-side auth & Firestore)
# Download service account key from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PRIVATE_KEY_ID=

# Agora (for video calls) - get from https://console.agora.io
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

#openAI key
OPENAI_API_KEY=