VITE_API_URL=http://localhost:3001

# WebSocket URL for real-time collaboration (y.js)
VITE_WS_URL=ws://localhost:3001/ws/collab

# Optional: AI backend (FastAPI) for transcription WebSocket. If set, transcription WS connects here instead of Express.
# VITE_AI_WS_URL=http://localhost:8000

# Firebase (get from Firebase Console > Project Settings > General)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
