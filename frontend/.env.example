# Express API (video token, calendar). Production: your Render Node URL (see render.yaml).
VITE_API_URL=http://localhost:3001

# FastAPI ai-backend: WebSocket /ws/transcription + POST /api/generate-summary + /api/ask.
# Required for live transcript and post-meeting AI notes. Local: run ai-backend on 8000.
# Production: your Render FastAPI URL (https://…). Vite maps wss:// → https:// for fetch().
VITE_AI_WS_URL=http://localhost:8000

# Optional: if HTTP and WS bases differ, set HTTP explicitly for REST (otherwise derived from VITE_AI_WS_URL).
# VITE_AI_HTTP_URL=https://your-ai-service.onrender.com

# WebRTC signaling (Notepad etc.)
# VITE_SIGNALING_URL=wss://your-signaling.onrender.com

# Firebase (get from Firebase Console > Project Settings > General)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Push notifications: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates (generate key pair)
VITE_VAPID_KEY=
