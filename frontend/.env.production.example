# Production backend URL (required for video call token + calendar ICS proxy on notusapp.com).
# Copy to .env.production and set to your deployed backend, e.g. https://api.notusapp.com
# Vite uses .env.production when you run: npm run build
VITE_API_URL=https://your-backend-url.example.com

# Firebase and other vars are inherited from .env; override here only if needed for production.
