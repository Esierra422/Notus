OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=notus-meetings
# Comma-separated browser origins (no spaces). Default in code is * so Firebase Hosting works without setting this.
# Example: https://notusapp.com,https://www.notusapp.com
CORS_ORIGIN=*
PORT=8000
# The FIREBASE_SERVICE_ACCOUNT_KEY has to be a one line JSON string like so 
FIREBASE_SERVICE_ACCOUNT_KEY=# {"type": "service_account", "project_id": "notus-e026b","private_key_id": "622891b26b5bafa33843e7a7a197cded1be6e244","private_key": "-----}