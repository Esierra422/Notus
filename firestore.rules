rules_version = '2';
// Deploy with: firebase deploy --only firestore
// Or paste into Firebase Console → Firestore Database → Rules
service cloud.firestore {
  match /databases/{database}/documents {

    function membershipData(orgId) {
      return get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data;
    }

    function activeOrgMember(orgId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
        && membershipData(orgId).state == 'active';
    }

    function isOrgOwnerOrAdmin(orgId) {
      return activeOrgMember(orgId)
        && membershipData(orgId).role in ['owner', 'admin'];
    }

    /** Members: optional capabilities map; owners/admins bypass. */
    function memCapScheduleOrg(m) {
      return m.role == 'owner' || m.role == 'admin'
        || !('capabilities' in m)
        || !(m.capabilities is map)
        || (('scheduleOrgMeetings' in m.capabilities) && m.capabilities.scheduleOrgMeetings == true)
        || (!('scheduleOrgMeetings' in m.capabilities)
          && ('scheduleMeetings' in m.capabilities)
          && m.capabilities.scheduleMeetings == true)
        || (!('scheduleOrgMeetings' in m.capabilities) && !('scheduleMeetings' in m.capabilities));
    }
    function memCapScheduleTeam(m) {
      return m.role == 'owner' || m.role == 'admin'
        || !('capabilities' in m)
        || !(m.capabilities is map)
        || (('scheduleTeamMeetings' in m.capabilities) && m.capabilities.scheduleTeamMeetings == true)
        || (!('scheduleTeamMeetings' in m.capabilities)
          && ('scheduleMeetings' in m.capabilities)
          && m.capabilities.scheduleMeetings == true)
        || (!('scheduleTeamMeetings' in m.capabilities) && !('scheduleMeetings' in m.capabilities));
    }
    function memCapCreateTeams(m) {
      return m.role == 'owner' || m.role == 'admin'
        || !('capabilities' in m)
        || !(m.capabilities is map)
        || !('createTeams' in m.capabilities)
        || m.capabilities.createTeams == true;
    }
    /** Org-wide visibility (non–invite-only) requires explicit orgCalendar == true when capabilities map exists. */
    function memCapOrgCal(m) {
      return m.role == 'owner' || m.role == 'admin'
        || !('capabilities' in m)
        || !(m.capabilities is map)
        || (('orgCalendar' in m.capabilities) && m.capabilities.orgCalendar == true);
    }
    /** Team-scoped meetings require explicit teamCalendar == true when capabilities map exists. */
    function memCapTeamCal(m) {
      return m.role == 'owner' || m.role == 'admin'
        || !('capabilities' in m)
        || !(m.capabilities is map)
        || (('teamCalendar' in m.capabilities) && m.capabilities.teamCalendar == true);
    }
    function meetingCreateAllowed(orgId, data) {
      return (data.scope != 'org' || data.inviteOnly == true || memCapOrgCal(membershipData(orgId)))
        && (data.scope != 'team' || memCapTeamCal(membershipData(orgId)))
        && (
          (data.scope == 'team' && memCapScheduleTeam(membershipData(orgId)))
          || ((data.scope == 'org' || data.scope == 'private') && memCapScheduleOrg(membershipData(orgId)))
        );
    }

    /** Update: only organizer or org owner/admin (matches client updateMeeting). */
    function isMeetingEditor(orgId) {
      return resource.data.createdBy == request.auth.uid
        || membershipData(orgId).role in ['owner', 'admin'];
    }

    /** Membership doc: always allow reading your own rows (lists orgs on login).
     *  Do not require orgId/userId keys on that path  -  older docs may omit a field and would
     *  otherwise make getUserMemberships() return permission-denied / empty.
     *  For other members’ rows: any active member of that org may read (getOrgMembers query).
     *  Requiring both orgId and userId on every doc broke queries when legacy rows omitted userId. */
    function canReadMembershipDoc() {
      return request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || (
            'orgId' in resource.data
            && resource.data.orgId is string
            && activeOrgMember(resource.data.orgId)
          )
        );
    }

    /** Org membership rows: only owners/admins or users with manageMembers capability. */
    function canWriteOrgMembershipDoc(orgId) {
      return activeOrgMember(orgId)
        && (
          membershipData(orgId).role in ['owner', 'admin']
          || (
            'capabilities' in membershipData(orgId)
            && membershipData(orgId).capabilities is map
            && ('manageMembers' in membershipData(orgId).capabilities)
            && membershipData(orgId).capabilities.manageMembers == true
          )
        );
    }

    /** Org event was invite-only; update makes it visible org-wide (inviteOnly cleared/false). */
    function meetingOrgInviteWidening() {
      return resource.data.scope == 'org'
        && resource.data.inviteOnly == true
        && request.resource.data.inviteOnly != true;
    }

    /** Prevent hijacking room id, transcript session, or organizer via direct SDK writes. */
    function meetingImmutableCore() {
      return resource.data.createdBy == request.resource.data.createdBy
        && (!('videoRoomId' in resource.data) || resource.data.videoRoomId == request.resource.data.videoRoomId)
        && (!('transcriptSessionId' in resource.data)
          || resource.data.transcriptSessionId == request.resource.data.transcriptSessionId)
        && (!('createdVia' in resource.data) || resource.data.createdVia == request.resource.data.createdVia);
    }

    /** Invitee removes only themselves from invitedUserIds (and private scopeInviteList stays in sync). */
    function meetingInviteeSelfDecline(orgId) {
      let prev = 'invitedUserIds' in resource.data ? resource.data.invitedUserIds : [];
      let next = 'invitedUserIds' in request.resource.data ? request.resource.data.invitedUserIds : [];
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return activeOrgMember(orgId)
        && request.auth.uid in prev
        && !(request.auth.uid in next)
        && prev.hasAll(next)
        && next.size() == prev.size() - 1
        && meetingImmutableCore()
        && (
          changed.hasOnly(['invitedUserIds'])
          || changed.hasOnly(['invitedUserIds', 'scopeInviteList'])
        )
        && (
          resource.data.scope != 'private'
          || request.resource.data.invitedUserIds == request.resource.data.get('scopeInviteList', [])
        );
    }
    // Users: any authenticated user can read (for org/team member display); only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      match /todos/{todoId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /importedCalendarEvents/{eventId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /blocked/{blockedUserId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /starred/{starredId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /fcmTokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      // In-app notifications (meeting invites, etc.)
      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.read == false
          && request.resource.data.type is string
          && request.resource.data.keys().hasAll(['type', 'read', 'createdBy', 'title']);
      }
    }

    // Organizations: any auth user can create (new org) or read; only org owner/admin may change org root doc
    match /organizations/{orgId} {
      allow create, read: if request.auth != null;
      allow update, delete: if isOrgOwnerOrAdmin(orgId);

      // Teams: active org members only
      match /teams/{teamId} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active';
        allow create: if request.auth != null
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active'
          && (isOrgOwnerOrAdmin(orgId)
            || memCapCreateTeams(get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data));
        allow update: if request.auth != null
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active';
      }

      // Team memberships: active org members
      match /teamMemberships/{tmId} {
        allow read, create, update: if request.auth != null
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active';
      }

      // Meetings: members read; create/update need capability rules; update limited to editor + org-cal when widening visibility
      match /meetings/{meetingId} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active';
        allow update: if activeOrgMember(orgId)
          && meetingImmutableCore()
          && (
            (isMeetingEditor(orgId) && (!meetingOrgInviteWidening() || memCapOrgCal(membershipData(orgId))))
            || meetingInviteeSelfDecline(orgId)
          );
        allow create: if activeOrgMember(orgId)
          && meetingCreateAllowed(orgId, request.resource.data);
        allow delete: if request.auth != null
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active'
          && (resource.data.createdBy == request.auth.uid
            || get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.role in ['owner', 'admin']);
      }

      // Conversations (WhatsApp-style: DM, group, team chats)
      match /conversations/{convId} {
        allow read: if request.auth != null
          && request.auth.uid in resource.data.members
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active';
        allow create: if request.auth != null
          && request.auth.uid in request.resource.data.members
          && request.resource.data.members is list
          && request.resource.data.type is string
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active';
        allow update: if request.auth != null && request.auth.uid in resource.data.members;
        allow delete: if false;
        match /messages/{messageId} {
          allow read, create: if request.auth != null
            && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
            && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active'
            && request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)/conversations/$(convId)).data.members;
          allow update: if request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)/conversations/$(convId)).data.members
            && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
              || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attachment'])
              || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
              // Delete for me
              || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor'])
                && request.resource.data.deletedFor[request.auth.uid] == true)
              // Delete for everyone (sender-only soft delete)
              || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'attachment', 'reactions', 'replyTo', 'deletedForEveryone', 'deletedBy', 'deletedAt'])
                && resource.data.senderId == request.auth.uid
                && request.resource.data.deletedForEveryone == true
                && request.resource.data.deletedBy == request.auth.uid));
          allow delete: if request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)/conversations/$(convId)).data.members;
        }
        match /typing/{typerId} {
          allow read, write: if request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)/conversations/$(convId)).data.members;
        }
      }

      // Reports: any org member can create; admins can read
      match /reports/{reportId} {
        allow create: if request.auth != null
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active';
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active'
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.role in ['owner', 'admin'];
        allow update, delete: if false;
      }

      // Channels: active org members (legacy)
      match /channels/{channelId} {
        allow read, create: if request.auth != null
          && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
          && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active';
        allow update, delete: if false;
        match /messages/{messageId} {
          allow read, create: if request.auth != null
            && exists(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid))
            && get(/databases/$(database)/documents/memberships/$(orgId + '_' + request.auth.uid)).data.state == 'active';
          allow update, delete: if false;
        }
      }
    }

    // Video channel chat: read scoped to everyone + direct messages involving the user; create/update authenticated
    match /videoChannels/{channelId} {
      match /messages/{msgId} {
        allow read: if request.auth != null
          && (
            !('audienceType' in resource.data)
            || resource.data.audienceType == 'everyone'
            || (resource.data.audienceType == 'direct'
              && (resource.data.senderId == request.auth.uid
                || resource.data.recipientId == request.auth.uid))
          );
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.keys().hasAll(['senderId', 'senderName', 'createdAt'])
          && (
            !('audienceType' in request.resource.data)
            || request.resource.data.audienceType == 'everyone'
            || (request.resource.data.audienceType == 'direct'
              && request.resource.data.recipientId is string
              && request.resource.data.recipientId != ''
              && request.resource.data.recipientId != request.auth.uid)
          );
        allow update: if request.auth != null;
        allow delete: if false;
      }
      // Participants: display names for video tiles (Agora uid -> displayName)
      match /participants/{participantId} {
        allow read, create, update, delete: if request.auth != null;
      }
      // Host end-for-all, screen-share policy (clients trust meeting.createdBy as hostUid)
      match /roomState/{docId} {
        allow read, write: if request.auth != null;
      }
      // Scheduled video: early joiners queue here until host admits or start time (see VideoCallPage)
      match /waiting/{waiterId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && request.auth.uid == waiterId;
      }
    }

    // Meeting transcripts: Admin SDK writes (bypasses rules); authenticated users can read
    match /meetingTranscripts/{channelName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Meeting summaries: authenticated user can read their own; Admin SDK creates
    match /meetingSummaries/{summaryId} {
      allow read: if request.auth != null
        && resource.data.generatedBy == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Memberships: doc id must be orgId_userId; reads scoped to self or same-org active members
    match /memberships/{membershipId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['orgId', 'userId', 'role', 'state'])
        && membershipId == request.resource.data.orgId + '_' + request.resource.data.userId;
      allow read: if canReadMembershipDoc();
      allow update: if request.auth != null
        && resource.data.keys().hasAll(['orgId', 'userId'])
        && request.resource.data.orgId == resource.data.orgId
        && request.resource.data.userId == resource.data.userId
        && canWriteOrgMembershipDoc(resource.data.orgId);
      allow delete: if false;
    }

    // Organization invitations: create by org admin; read/update by invitee (pending);
    // Org admins can read their org's invitations (incl. rejected) to see who declined.
    match /organizationInvitations/{invitationId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null
        && (resource.data.status == 'pending'
          || (resource.data.orgId != null
            && exists(/databases/$(database)/documents/memberships/$(resource.data.orgId + '_' + request.auth.uid))
            && get(/databases/$(database)/documents/memberships/$(resource.data.orgId + '_' + request.auth.uid)).data.state == 'active'
            && get(/databases/$(database)/documents/memberships/$(resource.data.orgId + '_' + request.auth.uid)).data.role in ['owner', 'admin']));
      allow delete: if false;
    }

    // Team invitations: create by team/org admin; read/update by invitee (pending)
    match /teamInvitations/{invitationId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null
        && resource.data.status == 'pending';
      allow delete: if false;
    }
  }
}
